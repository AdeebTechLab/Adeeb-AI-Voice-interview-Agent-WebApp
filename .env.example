# Copy to .env, then set ADMIN_PASSWORD before creating a public link.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-before-going-live

# Leave blank to store records in this project folder under data/.
# A relative value is resolved from app.py, not from the terminal working directory.
ADEEB_DATA_DIR=

# Candidate and HR links always use the host currently open in the browser.
# Do not save temporary Cloudflare hostnames in this file.


# Optional API brain. Recommended free-start provider: Groq.
# LLM_PROVIDER options: auto, groq, gemini, openrouter, ollama
# auto tries Groq -> Gemini -> OpenRouter -> local Ollama.
LLM_PROVIDER=auto
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1
# With the same Groq key, Urdu audio uses fast multilingual Whisper before the LLM brain.
# Set URDU_ASR_PROVIDER=local to keep all speech recognition on this computer.
URDU_ASR_PROVIDER=auto
GROQ_STT_ENABLED=true
# Use Groq Whisper for English, Urdu, Hindi, and mixed answers when a key is set.
# This is strongly recommended on slower computers; local Whisper remains the fallback.
GROQ_STT_ALL_LANGUAGES=true
GROQ_STT_MODEL=whisper-large-v3-turbo
GROQ_STT_ACCURACY_MODEL=whisper-large-v3
GROQ_STT_TIMEOUT_SECONDS=45
URDU_LLM_TRANSCRIPT_REPAIR=true
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=Adeeb AI Meeting Agent
GENERIC_AGENT_QUESTIONS=true

# Voice remains free with server-generated Edge neural TTS when ElevenLabs is empty.
# The browser provides the final fallback. ElevenLabs is optional and may have free-tier limits.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_VOICE_STABILITY=0.45
ELEVENLABS_VOICE_SIMILARITY=0.75


# Identity data is displayed in full only after HR sign-in, but stays protected at rest.
# FIRST_TIME_SETUP.bat generates both values; never share .env.
IDENTITY_ENCRYPTION_KEY=
CNIC_HMAC_SECRET=

# Local speech recognition fallback. In the staged flow the first four normal answers
# are queued; the final project answer and both follow-ups are transcribed immediately.
WHISPER_LIVE_MODEL=turbo
WHISPER_URDU_MODEL=turbo
URDU_WHISPER_BEAM_SIZE=8
URDU_SECOND_PASS_ON_LOW_CONFIDENCE=false
URDU_SECOND_PASS_MIN_CONFIDENCE=0.86
URDU_DIRECT_AUDIO_TRANSLATION=true
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_CPU_THREADS=0
WHISPER_NUM_WORKERS=1
WHISPER_BEAM_SIZE=5
VAD_MIN_SILENCE_MS=650
VAD_SPEECH_PAD_MS=360
LLM_DRIVEN_INTERVIEW=true
STAGED_INTERVIEW_FLOW=true
FAST_ANSWER_QUEUE=true
QUEUE_WAIT_POLL_SECONDS=0.50
QUEUE_MAX_WAIT_SECONDS=7200
STAGED_TRANSCRIPT_WAIT_SECONDS=150
# Keep false on slower PCs when Groq STT is configured. Local Whisper loads only if needed.
PRELOAD_LOCAL_WHISPER=false
MAX_AUDIO_MB=25

# Audio is retained by default so authenticated HR can replay every candidate answer.
# 0 means keep recordings until HR deletes them manually. Use a positive number to purge
# files older than that many days when the server next starts.
RETAIN_CANDIDATE_AUDIO=true
AUDIO_RETENTION_DAYS=0

# Requested readable HR archive. Each candidate receives data/candidates/<CNIC>/ with
# plaintext identity, transcript, conversation, JSON, and audio. This is sensitive data.
PLAINTEXT_CANDIDATE_DATA=true

# Urdu mode stays locked for short and long answers. When GROQ_API_KEY is configured,
# live Urdu ASR uses Groq for low latency and falls back to the local turbo model.
# Auto language retry is used only for genuinely mixed/auto input, not Urdu-locked turns.
AUTO_LANGUAGE_RETRY=true
AUTO_LANGUAGE_RETRY_MIN_CONFIDENCE=0.62

# Native Urdu/Hindi -> faithful English transcript. Ollama is local and optional,
# but recommended for English HR records. Install: ollama pull qwen2.5:3b-instruct
URDU_TRANSLATION_MODE=ollama_then_whisper
TRANSLATION_TIMEOUT_SECONDS=35
OLLAMA_INTERACTION_MODEL=qwen2.5:3b-instruct
OLLAMA_SUMMARY_MODEL=qwen2.5:3b-instruct
OLLAMA_BASE_URL=http://127.0.0.1:11434
INTERACTION_OLLAMA_TIMEOUT_SECONDS=18
OLLAMA_TIMEOUT_SECONDS=70
MAX_FOLLOWUPS_PER_QUESTION=2
MAX_FIELD_RELEVANT_QUESTIONS=3
MAX_PROJECT_RELEVANT_QUESTIONS=3

# Optional after-meeting high-accuracy pass. The live transcript is already used by the
# LLM during the interview; this optional pass only improves the final HR record. Leave false on a typical CPU-only laptop.
ENABLE_FINAL_RETRANSCRIBE=false
WHISPER_FINAL_MODEL=large-v3
FINAL_WHISPER_BEAM_SIZE=5

# Google Sheet RAG safety.
RAG_ALLOW_SENSITIVE=false

# PDF RAG import. Text-based PDFs work directly. Scanned image PDFs need OCR before upload.
MAX_PDF_UPLOAD_MB=15
MAX_PDF_PAGES=60
PDF_CHUNK_CHARS=1400
PDF_CHUNK_OVERLAP=180

# Live agent response limits.
AGENT_COMMAND_TIMEOUT_SECONDS=5
AGENT_TRANSLATION_TIMEOUT_SECONDS=5

# Browser interview screen auto-skips after one minute with no detected answer.
NO_RESPONSE_SKIP_SECONDS=60

# Server voice. In auto mode Urdu/Hindi use dedicated Edge voices first; English may use ElevenLabs first.
# Edge TTS needs internet but no API key and provides Urdu/Hindi/English MP3 audio
# to the browser, which is more reliable than depending on a phone's installed voices.
TTS_PROVIDER=auto
EDGE_TTS_ENABLED=true
EDGE_TTS_VOICE_EN=en-US-AriaNeural
EDGE_TTS_VOICE_UR=ur-PK-UzmaNeural
EDGE_TTS_VOICE_HI=hi-IN-SwaraNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_VOLUME=+0%
TTS_TIMEOUT_SECONDS=25

# Keep structured coverage. Q4 is a skill/problem follow-up based on the completed
# Q3 transcript; Q5 is a tailored project question followed by exactly two LLM follow-ups.
ADAPT_PLANNED_QUESTIONS=true
QUESTION_REPEAT_SIMILARITY=0.78
